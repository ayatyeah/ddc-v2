{
  "name": "ddc-admin-backend",
  "version": "2.0.0",
  "description": "DDC NBK — бэкенд (Express + PostgreSQL) + React-фронт (Vite). Приём заявок, новости, админ-панель.",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "node --watch server.js",
    "dev:client": "npm --prefix client run dev",
    "init-db": "node init-db.js",
    "build": "npm --prefix client install && npm --prefix client run build",
    "postinstall": "npm --prefix client install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0"
  }
}
