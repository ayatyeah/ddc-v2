# ── База данных (PostgreSQL) ──────────────────────────────────────────────────
# Скопируй в .env и подставь реальные значения. НЕ коммить .env в git.
PGUSER=doadmin
PGPASSWORD=__ВАШ_ПАРОЛЬ_БД__
PGHOST=__ВАШ_ХОСТ__.db.ondigitalocean.com
PGPORT=25060
PGDATABASE=defaultdb
PGSSLMODE=require

# ── Сервер ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Разрешённые источники (домены фронта) через запятую. На проде укажи реальный домен.
CORS_ORIGIN=https://ddc.example.kz

# ── Доступ администратора ─────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Смени на стойкий пароль (12+ символов). В проде "admin" вызовет предупреждение.
ADMIN_PASSWORD=__СТОЙКИЙ_ПАРОЛЬ__
# Секрет подписи JWT — длинная случайная строка (32+ символов). Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=__СГЕНЕРИРУЙТЕ_СЛУЧАЙНЫЙ_СЕКРЕТ__

# ── Gemini (ИИ-аналитика клиентов) ────────────────────────────────────────────
GEMINI_API_KEY=__ВАШ_КЛЮЧ_GEMINI__
GEMINI_MODEL=gemini-2.5-flash
